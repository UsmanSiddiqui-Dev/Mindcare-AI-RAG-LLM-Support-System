# Backend Configuration

# API Keys (Required)
OPENROUTER_API_KEY=sk_xxxxx_your_openrouter_key_here

# JWT Configuration (Required)
JWT_SECRET=your_secret_key_must_be_at_least_32_characters_long_for_security

# Database (Optional, defaults to SQLite)
# For SQLite: sqlite:///./mindcare.db
# For PostgreSQL: postgresql://user:password@localhost:5432/mindcare
DATABASE_URL=sqlite:///./mindcare.db

# Token Configuration
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS Configuration (comma-separated, no spaces)
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000,https://yourdomain.com

# Admin Emails (comma-separated)
ADMIN_EMAILS=admin@example.com
